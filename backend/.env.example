# ============================================
# STRAPI BACKEND - Production Environment Vars
# Set ALL of these in Railway → Variables tab
# ============================================

# Node environment
NODE_ENV=production
HOST=0.0.0.0
PORT=1337

# ---- Supabase PostgreSQL ----
DATABASE_CLIENT=postgres
# Paste your Supabase "Session mode" connection string here (port 5432)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL=true

# ---- Strapi Security Keys ----
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your_api_token_salt_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
JWT_SECRET=your_jwt_secret_here
TRANSFER_TOKEN_SALT=your_transfer_token_salt_here

# ---- Frontend URL (for CORS) ----
# Set this AFTER you deploy Astro to Vercel
ASTRO_FRONTEND_URL=https://your-project.vercel.app
