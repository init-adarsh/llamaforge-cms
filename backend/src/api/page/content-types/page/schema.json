      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.stats",
        "blocks.timeline",
        "blocks.features",
        "blocks.cta",
        "blocks.faq",
        "blocks.rich-text"
      ]
    }
  }
}
