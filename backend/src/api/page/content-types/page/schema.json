{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Standard pages and templates"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "parent": {
      "type": "integer",
      "default": 0
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "country",
        "about",
        "process",
        "faq"
      ],
      "default": "default",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "template_country": {
      "type": "component",
      "repeatable": false,
      "component": "templates.country",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "template_about": {
      "type": "component",
      "repeatable": false,
      "component": "templates.about",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "template_process": {
      "type": "component",
      "repeatable": false,
      "component": "templates.process",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "template_faq": {
      "type": "component",
      "repeatable": false,
      "component": "templates.faq",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.stats",
        "blocks.timeline",
        "blocks.features",
        "blocks.cta",
        "blocks.faq",
        "blocks.rich-text"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
