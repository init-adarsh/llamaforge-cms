---
import type { ACFCtaBlock } from '../../lib/blocks';

interface Props {
  block: ACFCtaBlock;
}
const { block } = Astro.props;

const variant = block.variant || 'dark';
---

<section class={`acf-cta-block cta-variant-${variant}`}>
  <div class="container cta-inner">
    <div class="cta-text">
      <h2 class="cta-headline">{block.headline}</h2>
      {block.description && <p class="cta-desc">{block.description}</p>}
    </div>
    <div class="cta-actions">
      {block.btn_text && block.btn_url && (
        <a href={block.btn_url} class={`btn ${variant === 'light' ? 'btn-primary' : 'btn-cta-primary'}`}>
          {block.btn_text}
        </a>
      )}
      {block.secondary_btn_text && block.secondary_btn_url && (
        <a href={block.secondary_btn_url} class={`btn ${variant === 'light' ? 'btn-secondary' : 'btn-cta-secondary'}`}>
          {block.secondary_btn_text}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .acf-cta-block {
    padding: 5rem 0;
    position: relative;
    overflow: hidden;
  }

  /* Dark variant */
  .cta-variant-dark {
    background-color: var(--primary-dark);
  }
  .cta-variant-dark::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 100% at 90% 50%, rgba(0,170,108,0.15) 0%, transparent 70%);
  }
  .cta-variant-dark .cta-headline { color: var(--text-light); }
  .cta-variant-dark .cta-desc { color: rgba(252, 251, 250, 0.7); }

  /* Green variant */
  .cta-variant-green {
    background-color: var(--accent-green);
  }
  .cta-variant-green .cta-headline { color: #fff; }
  .cta-variant-green .cta-desc { color: rgba(255,255,255,0.85); }

  /* Light variant */
  .cta-variant-light {
    background-color: var(--bg-sand);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }
  .cta-variant-light .cta-headline { color: var(--primary-dark); }
  .cta-variant-light .cta-desc { color: var(--text-muted); }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    position: relative;
    z-index: 1;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .cta-headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -1px;
    line-height: 1.2;
  }

  .cta-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 560px;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* Button overrides for dark/green variants */
  .btn-cta-primary {
    background-color: var(--accent-green);
    color: #fff;
    border-color: transparent;
  }
  .cta-variant-green .btn-cta-primary {
    background-color: #fff;
    color: var(--accent-green);
  }
  .btn-cta-primary:hover {
    background-color: var(--accent-green-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 170, 108, 0.3);
  }
  .cta-variant-green .btn-cta-primary:hover {
    background-color: rgba(255,255,255,0.9);
    color: var(--primary-dark);
  }

  .btn-cta-secondary {
    background-color: transparent;
    color: rgba(252, 251, 250, 0.85);
    border-color: rgba(252, 251, 250, 0.3);
  }
  .btn-cta-secondary:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: rgba(252, 251, 250, 0.6);
    color: #fff;
  }

  @media (max-width: 768px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-actions { width: 100%; }
    .cta-actions .btn { flex: 1; justify-content: center; }
  }
</style>
