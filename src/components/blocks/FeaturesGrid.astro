---
import type { ACFFeaturesBlock } from '../../lib/blocks';

interface Props {
  block: ACFFeaturesBlock;
}
const { block } = Astro.props;

const features = [
  { icon: block.feature_1_icon, title: block.feature_1_title, text: block.feature_1_text },
  { icon: block.feature_2_icon, title: block.feature_2_title, text: block.feature_2_text },
  { icon: block.feature_3_icon, title: block.feature_3_title, text: block.feature_3_text },
  { icon: block.feature_4_icon, title: block.feature_4_title, text: block.feature_4_text },
  { icon: block.feature_5_icon, title: block.feature_5_title, text: block.feature_5_text },
  { icon: block.feature_6_icon, title: block.feature_6_title, text: block.feature_6_text },
].filter((f) => f.title);
---

{features.length > 0 && (
  <section class="acf-features-block">
    <div class="container">
      {(block.title || block.description || block.badge_text) && (
        <div class="features-header">
          {block.badge_text && <span class="section-badge">{block.badge_text}</span>}
          {block.title && <h2 class="features-title">{block.title}</h2>}
          {block.description && <p class="features-desc">{block.description}</p>}
        </div>
      )}

      <div class={`features-grid features-count-${Math.min(features.length, 3)}`}>
        {features.map((feat) => (
          <div class="feat-card">
            {feat.icon && (
              <div class="feat-icon-wrap">
                <span class="feat-icon">{feat.icon}</span>
              </div>
            )}
            <h3 class="feat-title">{feat.title}</h3>
            {feat.text && <p class="feat-text">{feat.text}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .acf-features-block {
    padding: var(--section-padding);
    background-color: var(--bg-sand);
    border-bottom: 1px solid var(--border-color);
  }

  .features-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-badge {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-green);
  }

  .features-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -1px;
    line-height: 1.15;
    color: var(--primary-dark);
  }

  .features-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    gap: 1.5rem;
  }

  .features-count-1 { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  .features-count-2 { grid-template-columns: repeat(2, 1fr); }
  .features-count-3 { grid-template-columns: repeat(3, 1fr); }

  .feat-card {
    background-color: var(--bg-cream);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .feat-card:hover {
    border-color: var(--accent-green);
    box-shadow: 0 12px 32px rgba(15, 62, 43, 0.06);
    transform: translateY(-4px);
  }

  .feat-icon-wrap {
    width: 56px;
    height: 56px;
    background-color: var(--accent-mint);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feat-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .feat-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--primary-dark);
    letter-spacing: -0.25px;
  }

  .feat-text {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  @media (max-width: 992px) {
    .features-count-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 576px) {
    .features-grid { grid-template-columns: 1fr !important; }
  }
</style>
