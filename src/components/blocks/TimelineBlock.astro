---
import type { ACFTimelineBlock } from '../../lib/blocks';

interface Props {
  block: ACFTimelineBlock;
}
const { block } = Astro.props;

// Build steps array from flat fields
const steps = [
  { title: block.step_1_title, description: block.step_1_description },
  { title: block.step_2_title, description: block.step_2_description },
  { title: block.step_3_title, description: block.step_3_description },
  { title: block.step_4_title, description: block.step_4_description },
  { title: block.step_5_title, description: block.step_5_description },
  { title: block.step_6_title, description: block.step_6_description },
].filter((s) => s.title);
---

{steps.length > 0 && (
  <section class="acf-timeline-block">
    <div class="container">
      <div class="timeline-header">
        {block.badge_text && <span class="section-badge">{block.badge_text}</span>}
        {block.title && <h2 class="timeline-title">{block.title}</h2>}
        {block.description && <p class="timeline-desc">{block.description}</p>}
      </div>

      <div class="timeline-list">
        {steps.map((step, i) => (
          <div class="timeline-step">
            <div class="step-connector">
              <div class="step-dot">
                <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              {i < steps.length - 1 && <div class="step-line"></div>}
            </div>
            <div class="step-body">
              <h3 class="step-title">{step.title}</h3>
              {step.description && <p class="step-desc">{step.description}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .acf-timeline-block {
    padding: var(--section-padding);
    background-color: var(--bg-cream);
    border-bottom: 1px solid var(--border-color);
  }

  .timeline-header {
    max-width: 640px;
    margin: 0 auto 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-badge {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-green);
  }

  .timeline-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -1px;
    line-height: 1.15;
    color: var(--primary-dark);
  }

  .timeline-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .timeline-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 800px;
    margin: 0 auto;
  }

  .timeline-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    align-items: flex-start;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .step-dot {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--primary-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 6px rgba(15, 62, 43, 0.06);
    transition: background-color 0.25s;
  }

  .timeline-step:hover .step-dot {
    background-color: var(--accent-green);
  }

  .step-num {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 900;
    color: var(--accent-mint);
    letter-spacing: 0;
  }

  .step-line {
    width: 2px;
    flex: 1;
    min-height: 48px;
    background: linear-gradient(to bottom, var(--primary-dark), var(--border-color));
    margin: 4px 0;
  }

  .step-body {
    padding: 1rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .step-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--primary-dark);
    letter-spacing: -0.25px;
  }

  .step-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 580px;
  }

  @media (max-width: 576px) {
    .timeline-step {
      grid-template-columns: 50px 1fr;
      gap: 1rem;
    }
    .step-dot { width: 46px; height: 46px; }
    .step-num { font-size: 0.85rem; }
    .step-body { padding-bottom: 2rem; }
  }
</style>
