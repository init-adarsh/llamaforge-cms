---
import type { ACFHeroBlock } from '../../lib/blocks';

interface Props {
  block: ACFHeroBlock;
}
const { block } = Astro.props;
---

<section class="acf-hero-block">
  <div class="container acf-hero-inner">
    <div class="acf-hero-text">
      {block.badge_text && (
        <span class="acf-hero-badge">{block.badge_text}</span>
      )}
      <h1 class="acf-hero-headline">{block.headline}</h1>
      {block.subheadline && (
        <p class="acf-hero-sub">{block.subheadline}</p>
      )}
      <div class="acf-hero-ctas">
        {block.cta_text && block.cta_url && (
          <a href={block.cta_url} class="btn btn-primary">{block.cta_text}</a>
        )}
        {block.secondary_cta_text && block.secondary_cta_url && (
          <a href={block.secondary_cta_url} class="btn btn-secondary">{block.secondary_cta_text}</a>
        )}
      </div>
    </div>

    <!-- Decorative accent -->
    <div class="acf-hero-accent" aria-hidden="true">
      <div class="accent-ring ring-1"></div>
      <div class="accent-ring ring-2"></div>
      <div class="accent-ring ring-3"></div>
    </div>
  </div>
</section>

<style>
  .acf-hero-block {
    background-color: var(--primary-dark);
    padding: 7rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .acf-hero-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 70% 50%, rgba(0,170,108,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .acf-hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  .acf-hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 680px;
  }

  .acf-hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-green);
    background-color: rgba(0,170,108,0.1);
    border: 1px solid rgba(0,170,108,0.25);
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    width: fit-content;
  }

  .acf-hero-headline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    letter-spacing: -2px;
    color: var(--text-light);
  }

  .acf-hero-sub {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: rgba(252, 251, 250, 0.75);
    line-height: 1.6;
    max-width: 580px;
  }

  .acf-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  /* Decorative rings */
  .acf-hero-accent {
    position: absolute;
    right: -5%;
    top: 50%;
    transform: translateY(-50%);
    width: 500px;
    height: 500px;
    pointer-events: none;
  }

  .accent-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(0, 170, 108, 0.15);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ring-1 { width: 200px; height: 200px; border-color: rgba(0,170,108,0.3); }
  .ring-2 { width: 350px; height: 350px; border-color: rgba(0,170,108,0.15); }
  .ring-3 { width: 500px; height: 500px; border-color: rgba(0,170,108,0.07); }

  @media (max-width: 768px) {
    .acf-hero-block { padding: 5rem 0 4rem; }
    .acf-hero-accent { display: none; }
    .acf-hero-ctas { flex-direction: column; }
    .acf-hero-ctas .btn { width: 100%; }
  }
</style>
