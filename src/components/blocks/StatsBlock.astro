---
import type { ACFStatsBlock } from '../../lib/blocks';

interface Props {
  block: ACFStatsBlock;
}
const { block } = Astro.props;

// Build an array of stats from the flat fields, filtering empty ones
const stats = [
  { number: block.stat_1_number, label: block.stat_1_label, description: block.stat_1_description },
  { number: block.stat_2_number, label: block.stat_2_label, description: block.stat_2_description },
  { number: block.stat_3_number, label: block.stat_3_label, description: block.stat_3_description },
  { number: block.stat_4_number, label: block.stat_4_label, description: block.stat_4_description },
].filter((s) => s.number && s.label);
---

{stats.length > 0 && (
  <section class="acf-stats-block">
    <div class="container">
      {(block.title || block.description) && (
        <div class="stats-header">
          {block.title && <h2 class="stats-title">{block.title}</h2>}
          {block.description && <p class="stats-desc">{block.description}</p>}
        </div>
      )}
      <div class={`stats-grid stats-count-${stats.length}`}>
        {stats.map((stat, i) => (
          <div class="stat-card">
            <div class="stat-index">{String(i + 1).padStart(2, '0')}</div>
            <div class="stat-number">{stat.number}</div>
            <div class="stat-label">{stat.label}</div>
            {stat.description && <p class="stat-description">{stat.description}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .acf-stats-block {
    padding: var(--section-padding);
    background-color: var(--bg-sand);
    border-bottom: 1px solid var(--border-color);
  }

  .stats-header {
    text-align: center;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stats-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -1px;
    color: var(--primary-dark);
  }

  .stats-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  .stats-grid {
    display: grid;
    gap: 2px;
    background-color: var(--border-color);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    overflow: hidden;
  }

  .stats-count-1 { grid-template-columns: 1fr; }
  .stats-count-2 { grid-template-columns: repeat(2, 1fr); }
  .stats-count-3 { grid-template-columns: repeat(3, 1fr); }
  .stats-count-4 { grid-template-columns: repeat(4, 1fr); }

  .stat-card {
    background-color: var(--bg-cream);
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    transition: background-color 0.2s ease;
  }

  .stat-card:hover {
    background-color: var(--accent-mint);
  }

  .stat-index {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1;
    color: var(--primary-dark);
  }

  .stat-label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--primary-dark);
  }

  .stat-description {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  @media (max-width: 992px) {
    .stats-count-4 { grid-template-columns: repeat(2, 1fr); }
    .stats-count-3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 576px) {
    .stats-grid { grid-template-columns: 1fr !important; }
    .stat-card { padding: 2rem 1.5rem; }
  }
</style>
