---
import { fetchPosts } from '../lib/wordpress';

const posts = await fetchPosts();
---

<section class="blog-section section-sand" id="blog">
  <div class="container blog-container">
    <div class="blog-header fade-in-up">
      <span class="section-badge">AI Engineering</span>
      <h2 class="blog-title">Fine-Tuning & AI Research</h2>
      <p class="blog-subtitle">
        Stay up-to-date with our latest engineering write-ups, model benchmarking, and guides on fine-tuning open-source LLMs.
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="blog-grid fade-in-up" style="animation-delay: 0.15s;">
        {posts.map((post) => (
          <article class="blog-card">
            <div class="card-meta">
              <span class="card-date">
                {new Date(post.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
              <span class="card-category">AI Engineering</span>
            </div>
            
            <h3 class="card-title">
              <a href={`/posts/${post.slug}`} set:html={post.title.rendered} />
            </h3>
            
            <div class="card-excerpt" set:html={post.excerpt.rendered} />
            
            <a href={`/posts/${post.slug}`} class="btn-link card-link">
              Read Article &rarr;
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="blog-empty fade-in-up" style="animation-delay: 0.15s;">
        <svg class="empty-icon" width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19ZM17 12H7V14H17V12ZM14 15H7V17H14V15ZM17 9H7V11H17V9Z" fill="var(--text-muted)"/>
        </svg>
        <h3>No Insights Published Yet</h3>
        <p>
          Publish a post in your WordPress Admin Panel at <a href="http://tnv-headless.local/wp-admin/" target="_blank" class="wp-admin-link">tnv-headless.local/wp-admin/</a> to see it appear here dynamically!
        </p>
      </div>
    )}
  </div>
</section>

<style>
  .blog-section {
    padding: var(--section-padding);
    background-color: var(--bg-sand);
    border-bottom: 1px solid var(--border-color);
  }

  .blog-container {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .blog-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-badge {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-green);
    letter-spacing: 2px;
  }

  .blog-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .blog-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Grid Layout */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
    width: 100%;
  }

  .blog-card {
    background-color: var(--bg-cream);
    border-radius: 24px;
    padding: 2.5rem;
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 30px rgba(15, 62, 43, 0.05);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .card-date {
    color: var(--text-muted);
  }

  .card-category {
    color: var(--accent-green);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .card-title a {
    color: var(--primary-dark);
  }

  .card-title a:hover {
    color: var(--accent-green);
  }

  .card-excerpt {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Excerpt paragraph overrides */
  .card-excerpt :global(p) {
    margin: 0;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .card-link {
    align-self: flex-start;
    margin-top: auto;
    font-size: 0.9rem;
  }

  /* Empty state */
  .blog-empty {
    background-color: var(--bg-cream);
    border-radius: 28px;
    padding: 4rem 2rem;
    border: 2px dashed var(--border-color);
    text-align: center;
    max-width: 600px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .empty-icon {
    color: var(--text-muted);
    opacity: 0.5;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.05); opacity: 0.8; }
  }

  .blog-empty h3 {
    font-size: 1.5rem;
    color: var(--primary-dark);
  }

  .blog-empty p {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 450px;
  }

  .wp-admin-link {
    color: var(--accent-green);
    font-weight: 700;
  }

  .wp-admin-link:hover {
    color: var(--primary-dark);
    text-decoration: underline;
  }
</style>
