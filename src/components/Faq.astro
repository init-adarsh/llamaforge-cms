---
---
<section class="faq-section" id="faq">
  <div class="container faq-container">
    <div class="faq-header fade-in-up">
      <span class="section-badge">Got Questions?</span>
      <h2 class="faq-title">Frequently Asked Questions</h2>
      <p class="faq-subtitle">
        Everything you need to know about fine-tuning, serverless deployment, and GPU computing on LlamaForge.
      </p>
    </div>

    <!-- Accordion Group -->
    <div class="faq-list fade-in-up" style="animation-delay: 0.15s;">
      <!-- Q1 -->
      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>What is LlamaForge?</span>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="faq-panel">
          <div class="faq-content-inner">
            <p>
              LlamaForge is a managed SaaS platform designed to fine-tune and run open-source Large Language Models (LLMs) like Llama 3, Mistral, and Gemma. We handle all the complex GPU resource allocation, training pipelines, and serving optimizations, providing you with a simple, high-performance API endpoint.
            </p>
          </div>
        </div>
      </div>

      <!-- Q2 -->
      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>How long does it take to fine-tune a model?</span>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="faq-panel">
          <div class="faq-content-inner">
            <p>
              Typically, fine-tuning takes between 10 minutes to a few hours depending on the size of your dataset and the base model (e.g., Llama 3 8B vs 70B). LlamaForge leverages hyper-optimized training configs on NVIDIA GPUs to complete runs as fast as possible.
            </p>
          </div>
        </div>
      </div>

      <!-- Q3 -->
      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Are my training datasets and model weights secure?</span>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="faq-panel">
          <div class="faq-content-inner">
            <p>
              Yes, we take security very seriously. All uploaded datasets and trained weights are isolated in secure storage buckets and encrypted at rest and in transit. Your models are strictly private and never used to train other models or accessible by third parties.
            </p>
          </div>
        </div>
      </div>

      <!-- Q4 -->
      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>What GPUs do you use for training and inference?</span>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="faq-panel">
          <div class="faq-content-inner">
            <p>
              We run our training and inference jobs on enterprise-grade NVIDIA hardware, specifically NVIDIA H100, A100, and L4 GPUs. This ensures stable performance, fast training times, and low-latency completions.
            </p>
          </div>
        </div>
      </div>

      <!-- Q5 -->
      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Can I export my fine-tuned model weights?</span>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="faq-panel">
          <div class="faq-content-inner">
            <p>
              Absolutely. Unlike locked-in provider APIs, LlamaForge supports weight exporting. Once your fine-tuning job is complete, you can download your LoRA adapters or merged GGUF/Safetensors weights to run them locally on your own hardware.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: var(--section-padding);
    background-color: var(--bg-cream);
    border-bottom: 1px solid var(--border-color);
  }

  .faq-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  .faq-header {
    text-align: center;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-badge {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-green);
    letter-spacing: 2px;
  }

  .faq-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .faq-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Accordion Item Styling */
  .faq-list {
    width: 100%;
    max-width: 750px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background-color: var(--bg-sand);
    border-radius: 16px;
    border: 1px solid var(--border-color);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-item:hover {
    border-color: var(--primary-dark);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    background: transparent;
    border: none;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--primary-dark);
    text-align: left;
    cursor: pointer;
    outline: none;
  }

  .chevron-icon {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    color: var(--primary-dark);
    flex-shrink: 0;
  }

  .faq-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-content-inner {
    padding: 0 2rem 1.5rem 2rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Open States */
  .faq-item.open {
    border-color: var(--accent-green);
    background-color: var(--bg-cream);
    box-shadow: 0 8px 24px rgba(15, 62, 43, 0.03);
  }

  .faq-item.open .chevron-icon {
    transform: rotate(180deg);
    color: var(--accent-green);
  }
</style>

<script>
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach(item => {
    const trigger = item.querySelector('.faq-trigger');
    const panel = item.querySelector('.faq-panel') as HTMLDivElement;

    if (trigger && panel) {
      trigger.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');

        // Close all other items first (optional accordion behavior)
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('open');
            const otherPanel = otherItem.querySelector('.faq-panel') as HTMLDivElement;
            const otherTrigger = otherItem.querySelector('.faq-trigger');
            if (otherPanel) otherPanel.style.maxHeight = '0px';
            if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
          }
        });

        // Toggle current item
        if (isOpen) {
          item.classList.remove('open');
          panel.style.maxHeight = '0px';
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('open');
          panel.style.maxHeight = panel.scrollHeight + 'px';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    }
  });
</script>
