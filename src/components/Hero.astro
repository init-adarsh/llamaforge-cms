---
import { fetchPageBySlug } from '../lib/wordpress';

const homePage = await fetchPageBySlug('home');

const title = homePage ? homePage.title.rendered : 'Fine-tune & run<br />local LLMs, instantly.';
const subtitle = homePage && homePage.excerpt.rendered 
  ? homePage.excerpt.rendered.replace(/<[^>]*>/g, '').trim()
  : 'LlamaForge provides serverless GPU infrastructure to fine-tune, optimize, and serve open-source LLMs like Llama 3, Mistral, and Phi-3 with a single API call.';
---
<section class="hero-section">
  <div class="container hero-container">
    <div class="hero-content fade-in-up">
      <h1 class="hero-title" set:html={title} />
      <p class="hero-subtitle" set:html={subtitle} />
      <div class="hero-ctas">
        <a href="#pricing" class="btn btn-primary">Start Fine-Tuning</a>
        <a href="#video-modal" class="btn-link hero-video-link" id="play-video-trigger">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M10 8L16 12L10 16V8Z" fill="currentColor"/>
          </svg>
          Watch Demo
        </a>
      </div>
    </div>

    <!-- Interactive Hero Video Card -->
    <div class="hero-video-wrapper fade-in-up" style="animation-delay: 0.2s;">
      <div class="video-card" id="video-card-element">
        <img 
          src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=960&h=540" 
          alt="LlamaForge Fine-tuning Platform" 
          class="video-poster-img"
        />
        <div class="video-overlay">
          <button class="play-button" aria-label="Play video">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5V19L19 12L8 5Z" fill="#0f3e2b"/>
            </svg>
          </button>
          <span class="video-badge">WATCH PLATFORM DEMO</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Simple HTML/CSS Lightbox Video Modal (pure client-side) -->
<div class="video-modal" id="video-modal">
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-content">
    <button class="modal-close" id="modal-close" aria-label="Close video">&times;</button>
    <div class="video-responsive-container">
      <iframe 
        id="video-iframe"
        width="560" 
        height="315" 
        src="https://www.youtube-nocookie.com/embed/dQw4w9WgXcQ" 
        title="YouTube video player" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<style>
  .hero-section {
    padding-top: 120px; /* offset header height */
    padding-bottom: 50px;
    background-color: var(--bg-cream);
    text-align: center;
    overflow: hidden;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .hero-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 1.1;
    color: var(--primary-dark);
    letter-spacing: -2px;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    max-width: 600px;
    color: var(--text-muted);
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
  }

  .hero-video-link {
    font-size: 1.05rem;
  }

  /* Video Wrapper */
  .hero-video-wrapper {
    width: 100%;
    max-width: 960px;
    margin-top: 1rem;
  }

  .video-card {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(15, 62, 43, 0.08), 0 1px 3px rgba(15, 62, 43, 0.02);
    border: 1px solid var(--border-color);
    background-color: var(--bg-sand);
    cursor: pointer;
  }

  .video-poster-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .video-card:hover .video-poster-img {
    transform: scale(1.03);
  }

  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(15, 62, 43, 0.3) 0%, rgba(15, 62, 43, 0) 50%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    transition: background-color 0.3s ease;
  }

  .video-card:hover .video-overlay {
    background-color: rgba(15, 62, 43, 0.1);
  }

  .play-button {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--bg-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    padding-left: 5px; /* offset play icon offset */
  }

  .video-card:hover .play-button {
    transform: scale(1.1);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
    background-color: var(--accent-mint);
  }

  .video-badge {
    position: absolute;
    bottom: 2rem;
    background-color: var(--accent-mint);
    color: var(--primary-dark);
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 2px;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid var(--border-color);
  }

  /* Video Lightbox Modal */
  .video-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .video-modal.open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(15, 62, 43, 0.85);
    backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    width: 100%;
    max-width: 900px;
    aspect-ratio: 16/9;
    background-color: #000;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
    z-index: 2001;
  }

  .video-responsive-container {
    width: 100%;
    height: 100%;
  }

  .video-responsive-container iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    color: white;
    font-size: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2002;
    transition: background-color 0.2s;
  }

  .modal-close:hover {
    background-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 576px) {
    .hero-ctas {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    .hero-ctas .btn {
      width: 100%;
    }
    .play-button {
      width: 60px;
      height: 60px;
    }
  }
</style>

<script>
  const videoCard = document.getElementById('video-card-element');
  const playTrigger = document.getElementById('play-video-trigger');
  const modal = document.getElementById('video-modal');
  const closeBtn = document.getElementById('modal-close');
  const backdrop = document.getElementById('modal-backdrop');
  const iframe = document.getElementById('video-iframe') as HTMLIFrameElement;
  const originalSrc = iframe ? iframe.src : '';

  function openModal() {
    if (modal && iframe) {
      // Use LlamaForge product demo video
      iframe.src = "https://www.youtube-nocookie.com/embed/6p_y56N63pE?autoplay=1";
      modal.classList.add('open');
      document.body.classList.add('overflow-hidden');
    }
  }

  function closeModal() {
    if (modal && iframe) {
      iframe.src = "";
      modal.classList.remove('open');
      document.body.classList.remove('overflow-hidden');
    }
  }

  if (videoCard) videoCard.addEventListener('click', openModal);
  if (playTrigger) {
    playTrigger.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (backdrop) backdrop.addEventListener('click', closeModal);
</script>
