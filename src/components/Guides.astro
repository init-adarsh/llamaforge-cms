---
---
<section class="guides-section section-sand" id="guides">
  <div class="container guides-container">
    <div class="guides-header fade-in-up">
      <span class="section-badge">AI Architects</span>
      <h2 class="guides-title">Meet Our Lead AI Architects</h2>
      <p class="guides-subtitle">
        World-class engineers and research professionals with decades of cumulative experience in machine learning and distributed GPU systems.
      </p>
    </div>

    <!-- Horizontal Row of Guides -->
    <div class="guides-slider fade-in-up" style="animation-delay: 0.15s;">
      <div class="guides-grid">
        <!-- Guide 1 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="Elena" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">Elena R.</h4>
            <p class="guide-role">Quality & Alignment (RLHF)</p>
          </div>
        </div>

        <!-- Guide 2 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="David" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">David K.</h4>
            <p class="guide-role">Security & VPC (ISO 27001)</p>
          </div>
        </div>

        <!-- Guide 3 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="Jess" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">Jess M.</h4>
            <p class="guide-role">Inference Scaling (vLLM)</p>
          </div>
        </div>

        <!-- Guide 4 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="Michael" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">Michael P.</h4>
            <p class="guide-role">CUDA Optimizations</p>
          </div>
        </div>

        <!-- Guide 5 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="Sofia" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">Sofia G.</h4>
            <p class="guide-role">Fine-Tuning Pipelines</p>
          </div>
        </div>

        <!-- Guide 6 -->
        <div class="guide-card">
          <div class="guide-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=300&h=400" 
              alt="Todd" 
              class="guide-img"
            />
          </div>
          <div class="guide-meta">
            <h4 class="guide-name">Todd S.</h4>
            <p class="guide-role">Edge Deployment (Ollama)</p>
          </div>
        </div>
      </div>
    </div>

    <div class="guides-action fade-in-up" style="animation-delay: 0.2s;">
      <a href="#pricing" class="btn btn-secondary">Meet All Architects</a>
    </div>
  </div>
</section>

<style>
  .guides-section {
    padding: var(--section-padding);
    background-color: var(--bg-sand);
    border-bottom: 1px solid var(--border-color);
  }

  .guides-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
  }

  .guides-header {
    text-align: center;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-badge {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-green);
    letter-spacing: 2px;
  }

  .guides-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .guides-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Slider container with scroll snap */
  .guides-slider {
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none; /* Hide standard Firefox scrollbar */
    padding-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
  }

  .guides-slider::-webkit-scrollbar {
    display: none; /* Hide Chrome scrollbar */
  }

  .guides-grid {
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
    width: max-content;
  }

  .guide-card {
    width: 200px;
    background-color: var(--bg-cream);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    box-shadow: 0 10px 20px rgba(15, 62, 43, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
    scroll-snap-align: center;
  }

  .guide-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(15, 62, 43, 0.08);
  }

  .guide-img-wrapper {
    width: 100%;
    aspect-ratio: 4/5;
    background-color: var(--bg-sand);
    overflow: hidden;
  }

  .guide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .guide-card:hover .guide-img {
    transform: scale(1.05);
  }

  .guide-meta {
    padding: 1.25rem;
    text-align: center;
  }

  .guide-name {
    font-size: 1rem;
    font-weight: 800;
    color: var(--primary-dark);
    margin-bottom: 0.15rem;
  }

  .guide-role {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--accent-green);
    letter-spacing: 1px;
  }

  .guides-action {
    display: flex;
    justify-content: center;
  }
</style>
