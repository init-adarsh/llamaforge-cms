---
---
<section class="outcomes-section" id="outcomes">
  <div class="container outcomes-container">
    <div class="outcomes-header fade-in-up">
      <span class="section-badge">Platform Stats</span>
      <h2 class="outcomes-title">Empowering developer efficiency and AI scalability.</h2>
      <p class="outcomes-subtitle">
        LlamaForge provides a robust, GPU-backed fine-tuning platform that cuts inference costs and accelerates your time-to-market.
      </p>
    </div>

    <div class="outcomes-grid">
      <!-- Card 1: Main Stat -->
      <div class="outcome-card card-featured fade-in-up">
        <span class="card-tag">Fine-Tuned Models</span>
        <h3 class="card-metric">25,000+</h3>
        <p class="card-desc">Custom model versions fine-tuned and deployed by developers globally.</p>
        <div class="card-detail">Optimized weights stored securely.</div>
      </div>

      <!-- Card 2: Cost Saving -->
      <div class="outcome-card fade-in-up" style="animation-delay: 0.1s;">
        <span class="card-tag tag-mint">Cost Saving</span>
        <h3 class="card-metric text-small">75%</h3>
        <p class="card-desc">Average reduction in monthly model querying and token execution costs.</p>
        <div class="card-detail">Highly optimized GPU usage.</div>
      </div>

      <!-- Card 3: Availability -->
      <div class="outcome-card fade-in-up" style="animation-delay: 0.2s;">
        <span class="card-tag tag-sand">Availability</span>
        <h3 class="card-metric">99.99%</h3>
        <p class="card-desc">Global API availability with active failover across our cluster nodes.</p>
        <div class="card-detail">Instant API failover and redundancy.</div>
      </div>

      <!-- Card 4: Speed -->
      <div class="outcome-card fade-in-up" style="animation-delay: 0.3s;">
        <span class="card-tag tag-mint">Speed</span>
        <h3 class="card-metric">3.2x</h3>
        <p class="card-desc">Inference latency acceleration using vLLM and FlashAttention-2 kernels.</p>
        <div class="card-detail">Optimized serving framework.</div>
      </div>
    </div>
  </div>
</section>

<style>
  .outcomes-section {
    padding: var(--section-padding);
    background-color: var(--bg-cream);
    border-bottom: 1px solid var(--border-color);
  }

  .outcomes-container {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .outcomes-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-badge {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-green);
    letter-spacing: 2px;
  }

  .outcomes-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .outcomes-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Grid Layout */
  .outcomes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .outcome-card {
    background-color: var(--bg-sand);
    border-radius: 24px;
    padding: 2.25rem 2rem;
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
  }

  .outcome-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(15, 62, 43, 0.05);
  }

  .card-featured {
    background-color: var(--primary-dark);
    color: var(--text-light);
    grid-column: span 1;
  }

  .card-featured .card-metric,
  .card-featured .card-desc,
  .card-featured .card-tag {
    color: var(--text-light);
  }

  .card-featured .card-detail {
    color: var(--accent-mint);
    border-top-color: rgba(255, 255, 255, 0.15);
  }

  .card-tag {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--primary-dark);
    letter-spacing: 1px;
    align-self: flex-start;
    padding: 0.35rem 0.75rem;
    background-color: rgba(0, 0, 0, 0.04);
    border-radius: 9999px;
  }

  .card-featured .card-tag {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .tag-mint {
    color: var(--accent-green);
    background-color: var(--accent-mint);
  }

  .tag-sand {
    color: #b27a3d;
    background-color: #fbf5ee;
  }

  .card-metric {
    font-size: 3.5rem;
    font-family: var(--font-serif);
    font-weight: 800;
    line-height: 1;
    color: var(--primary-dark);
  }

  .card-metric.text-small {
    font-size: 2.8rem;
    margin-top: 0.7rem;
    margin-bottom: 0.5rem;
  }

  .card-desc {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-dark);
  }

  .card-detail {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 700;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  @media (max-width: 1200px) {
    .outcomes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .outcomes-grid {
      grid-template-columns: 1fr;
    }
    .outcome-card {
      padding: 1.75rem 1.5rem;
    }
  }
</style>
