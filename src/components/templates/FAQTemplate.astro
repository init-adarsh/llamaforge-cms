---
interface Props {
  data: {
    faq_heading: string;
    faq_description?: string;
    q1?: string;
    a1?: string;
    q2?: string;
    a2?: string;
    q3?: string;
    a3?: string;
    q4?: string;
    a4?: string;
    q5?: string;
    a5?: string;
  };
}

const { data } = Astro.props;

const faqs = [
  { q: data.q1, a: data.a1 },
  { q: data.q2, a: data.a2 },
  { q: data.q3, a: data.a3 },
  { q: data.q4, a: data.a4 },
  { q: data.q5, a: data.a5 },
].filter(f => f.q && f.a);
---

<div class="faq-template">
  <!-- Intro Section -->
  <section class="faq-intro">
    <div class="container intro-container">
      <span class="section-badge">Support Desk</span>
      <h1 class="intro-title font-serif">{data.faq_heading}</h1>
      {data.faq_description && <p class="intro-desc">{data.faq_description}</p>}
    </div>
  </section>

  <!-- Accordion List Section -->
  {faqs.length > 0 && (
    <section class="faq-accordions section-sand">
      <div class="container accordion-container">
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <div class="faq-item" class:list={[{ active: index === 0 }]}>
              <button class="faq-question font-serif">
                <span>{faq.q}</span>
                <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="faq-answer-wrapper">
                <div class="faq-answer">
                  <p>{faq.a}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</div>

<style>
  .faq-template {
    padding-top: 70px;
    background-color: var(--bg-cream);
  }

  .faq-intro {
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .intro-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .intro-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: var(--primary-dark);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.15;
    letter-spacing: -1.5px;
  }

  .intro-desc {
    font-size: 1.25rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 650px;
    margin: 0 auto;
  }

  /* Accordion Layout */
  .faq-accordions {
    padding: 6rem 1.5rem 8rem;
    border-top: 1px solid var(--border-color);
  }

  .accordion-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background-color: var(--bg-cream);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.active {
    border-color: var(--primary-dark);
    box-shadow: 0 10px 30px rgba(15, 62, 43, 0.03);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.75rem 2rem;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--primary-dark);
    font-family: var(--font-serif);
    transition: color 0.25s ease;
  }

  .faq-question:hover {
    color: var(--accent-green);
  }

  .faq-icon {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .faq-item.active .faq-icon {
    transform: rotate(180deg);
    color: var(--primary-dark);
  }

  .faq-answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.active .faq-answer-wrapper {
    grid-template-rows: 1fr;
  }

  .faq-answer {
    overflow: hidden;
  }

  .faq-answer p {
    padding: 0 2rem 2rem 2rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0;
  }
</style>

<script>
  // Setup accordion toggle event listeners on load
  const setupAccordions = () => {
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question');
      if (btn) {
        btn.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Collapse all others
          faqItems.forEach(i => i.classList.remove('active'));
          
          // Toggle current
          if (!isActive) {
            item.classList.add('active');
          }
        });
      }
    });
  };

  // Run immediately and on view transitions / navigations
  setupAccordions();
  document.addEventListener('astro:after-swap', setupAccordions);
</script>
