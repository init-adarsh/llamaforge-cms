---
interface Props {
  data: {
    story_heading: string;
    story_content?: string;
    mission_heading?: string;
    mission_content?: string;
    vision_heading?: string;
    vision_content?: string;
    team_heading?: string;
    team_intro?: string;
  };
}

const { data } = Astro.props;
---

<div class="about-template">
  <!-- Story Section -->
  <section class="about-story">
    <div class="container story-container">
      <span class="section-badge">Our Legacy</span>
      <h1 class="story-title font-serif">{data.story_heading}</h1>
      {data.story_content && (
        <div class="story-content-text">
          <p>{data.story_content}</p>
        </div>
      )}
    </div>
  </section>

  <!-- Mission & Vision Section -->
  {(data.mission_heading || data.vision_heading) && (
    <section class="about-goals section-sand">
      <div class="container goals-grid">
        {data.mission_heading && (
          <div class="goal-card">
            <div class="goal-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <h2 class="goal-title font-serif">{data.mission_heading}</h2>
            <p class="goal-desc">{data.mission_content || 'Our mission is to build highly accessible, performant, and privacy-first local LLM services globally.'}</p>
          </div>
        )}
        
        {data.vision_heading && (
          <div class="goal-card">
            <div class="goal-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h2 class="goal-title font-serif">{data.vision_heading}</h2>
            <p class="goal-desc">{data.vision_content || 'Our vision is to empower every company to possess private, secure, and fully customized intelligence nodes.'}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Team Intro Section -->
  {data.team_heading && (
    <section class="about-team">
      <div class="container team-container">
        <span class="section-badge">The Brains</span>
        <h2 class="team-title font-serif">{data.team_heading}</h2>
        {data.team_intro && <p class="team-intro-text">{data.team_intro}</p>}
        
        <!-- Standard placeholder team grid for look-and-feel -->
        <div class="team-grid">
          <div class="team-member">
            <div class="member-avatar font-serif">AD</div>
            <div class="member-info">
              <h4>Adarsh</h4>
              <p>Founder & Chief Architect</p>
            </div>
          </div>
          <div class="team-member">
            <div class="member-avatar font-serif">AI</div>
            <div class="member-info">
              <h4>Antigravity</h4>
              <p>Lead AI Engineering Partner</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
</div>

<style>
  .about-template {
    padding-top: 70px;
    background-color: var(--bg-cream);
  }

  /* Story */
  .about-story {
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .story-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .story-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: var(--primary-dark);
    margin-top: 1rem;
    margin-bottom: 2rem;
    line-height: 1.15;
    letter-spacing: -1.5px;
  }

  .story-content-text {
    font-size: 1.2rem;
    line-height: 1.85;
    color: var(--text-dark);
    text-align: justify;
  }

  /* Goals */
  .about-goals {
    padding: 6rem 1.5rem;
  }

  .goals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .goal-card {
    background-color: var(--bg-cream);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 3rem 2.5rem;
    box-shadow: 0 10px 30px rgba(15, 62, 43, 0.02);
  }

  .goal-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background-color: var(--accent-mint);
    color: var(--accent-green);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .goal-title {
    font-size: 1.8rem;
    color: var(--primary-dark);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .goal-desc {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0;
  }

  /* Team */
  .about-team {
    padding: 6rem 1.5rem 8rem;
    text-align: center;
  }

  .team-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .team-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--primary-dark);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
  }

  .team-intro-text {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 3.5rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .team-member {
    background-color: var(--bg-sand);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid rgba(229, 223, 217, 0.5);
  }

  .member-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--primary-dark);
    color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
  }

  .member-info h4 {
    font-size: 1.25rem;
    color: var(--primary-dark);
    margin-bottom: 0.25rem;
    font-weight: 700;
  }

  .member-info p {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 600;
    margin: 0;
  }
</style>
