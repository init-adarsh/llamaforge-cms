---
interface Props {
  data: {
    process_heading: string;
    process_description?: string;
    step_1_title?: string;
    step_1_description?: string;
    step_2_title?: string;
    step_2_description?: string;
    step_3_title?: string;
    step_3_description?: string;
    step_4_title?: string;
    step_4_description?: string;
  };
}

const { data } = Astro.props;

const steps = [
  { num: 1, title: data.step_1_title, desc: data.step_1_description },
  { num: 2, title: data.step_2_title, desc: data.step_2_description },
  { num: 3, title: data.step_3_title, desc: data.step_3_description },
  { num: 4, title: data.step_4_title, desc: data.step_4_description },
].filter(s => s.title);
---

<div class="process-template">
  <!-- Intro Section -->
  <section class="process-intro">
    <div class="container intro-container">
      <span class="section-badge">How It Works</span>
      <h1 class="intro-title font-serif">{data.process_heading}</h1>
      {data.process_description && <p class="intro-desc">{data.process_description}</p>}
    </div>
  </section>

  <!-- Steps Timeline Section -->
  {steps.length > 0 && (
    <section class="process-timeline section-sand">
      <div class="container timeline-container">
        <div class="steps-flow">
          {steps.map((step, index) => (
            <div class="step-card fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
              <span class="step-badge-num">{step.num}</span>
              <div class="step-details">
                <h3 class="step-title font-serif">{step.title}</h3>
                <p class="step-text">{step.desc || 'Optimizing configuration and running checkpoints to ensure maximum token execution performance.'}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</div>

<style>
  .process-template {
    padding-top: 70px;
    background-color: var(--bg-cream);
  }

  .process-intro {
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .intro-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .intro-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: var(--primary-dark);
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.15;
    letter-spacing: -1.5px;
  }

  .intro-desc {
    font-size: 1.25rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 650px;
    margin: 0 auto;
  }

  /* Timeline Flow */
  .process-timeline {
    padding: 6rem 1.5rem 8rem;
    border-top: 1px solid var(--border-color);
  }

  .timeline-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .steps-flow {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
  }

  .steps-flow::before {
    content: '';
    position: absolute;
    top: 0;
    left: 28px;
    width: 2px;
    height: 100%;
    background-color: var(--border-color);
    z-index: 1;
  }

  @media (max-width: 576px) {
    .steps-flow::before {
      display: none;
    }
  }

  .step-card {
    background-color: var(--bg-cream);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 2.5rem 2rem 2.5rem 5rem;
    position: relative;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(15, 62, 43, 0.02);
  }

  @media (max-width: 576px) {
    .step-card {
      padding: 2.5rem 2rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
  }

  .step-badge-num {
    position: absolute;
    top: 50%;
    left: 12px;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--accent-green);
    color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    font-weight: 800;
  }

  @media (max-width: 576px) {
    .step-badge-num {
      position: static;
      transform: none;
      margin-bottom: 1.5rem;
    }
  }

  .step-title {
    font-size: 1.5rem;
    color: var(--primary-dark);
    margin-bottom: 0.75rem;
    letter-spacing: -0.5px;
  }

  .step-text {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }
</style>
