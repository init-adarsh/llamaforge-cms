---
---
<section class="how-it-works-section section-sand" id="method">
  <div class="container how-it-works-container">
    <!-- Left Column: Copy -->
    <div class="how-content fade-in-up">
      <span class="section-badge">Our Process</span>
      <h2 class="how-title">Model deployment made simple in four stages.</h2>
      <p class="how-text">
        LlamaForge simplifies open-source AI adoption, moving your models from raw data to scalable, low-latency API endpoints.
      </p>
      
      <!-- The 4 Stages List -->
      <ol class="rules-list">
        <li>
          <span class="rule-num">1</span>
          <div>
            <h3>Select & Configure Model</h3>
            <p>Choose from Llama 3, Mistral, or Phi-3, and set your baseline parameters.</p>
          </div>
        </li>
        <li>
          <span class="rule-num">2</span>
          <div>
            <h3>Prepare Training Data</h3>
            <p>Upload your JSONL dataset. LlamaForge automatically validates and structures your prompts.</p>
          </div>
        </li>
        <li>
          <span class="rule-num">3</span>
          <div>
            <h3>Fine-Tune with LoRA</h3>
            <p>Execute fine-tuning on serverless GPUs. Track validation loss in real time.</p>
          </div>
        </li>
        <li>
          <span class="rule-num">4</span>
          <div>
            <h3>Deploy Serverless API</h3>
            <p>Instantly access your custom model via a dedicated, secure, auto-scaling API endpoint.</p>
          </div>
        </li>
      </ol>

      <div class="how-ctas">
        <a href="#pricing" class="btn btn-primary">Start Fine-Tuning</a>
        <a href="#pricing" class="btn-link">View documentation &rarr;</a>
      </div>
    </div>

    <!-- Right Column: Interactive user cards -->
    <div class="how-visual fade-in-up" style="animation-delay: 0.2s;">
      <div class="user-cards-container">
        <!-- Card 1 -->
        <div class="user-card card-left">
          <div class="user-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&q=80&w=400&h=400" 
              alt="AeroSpace Corp AI Engineer" 
              class="user-img"
            />
          </div>
          <div class="user-info">
            <h4 class="user-name">AeroSpace Corp</h4>
            <p class="user-stat">Llama-3 fine-tuned in 12 mins</p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="user-card card-right">
          <div class="user-img-wrapper">
            <img 
              src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&q=80&w=400&h=400" 
              alt="FinTech CTO" 
              class="user-img"
            />
          </div>
          <div class="user-info">
            <h4 class="user-name">FinTech Systems</h4>
            <p class="user-stat">Mistral-7B serving 250 req/sec</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works-section {
    background-color: var(--bg-sand);
    border-bottom: 1px solid var(--border-color);
    overflow: hidden;
  }

  .how-it-works-container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: center;
  }

  /* Copy column */
  .how-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-badge {
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-green);
    letter-spacing: 2px;
  }

  .how-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .how-text {
    font-size: 1.1rem;
    max-width: 540px;
  }

  /* Rules List */
  .rules-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin: 1rem 0;
  }

  .rules-list li {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .rule-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background-color: var(--accent-mint);
    color: var(--primary-dark);
    font-weight: 800;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 0.9rem;
  }

  .rules-list h3 {
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
  }

  .rules-list p {
    font-size: 0.95rem;
  }

  .how-ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
  }

  /* User cards column */
  .user-cards-container {
    position: relative;
    height: 480px;
    width: 100%;
    max-width: 420px;
    margin: 0 auto;
  }

  .user-card {
    position: absolute;
    width: 240px;
    background-color: var(--bg-cream);
    border-radius: 20px;
    padding: 1.25rem;
    box-shadow: 0 15px 30px rgba(15, 62, 43, 0.08), 0 1px 3px rgba(15, 62, 43, 0.02);
    border: 1px solid var(--border-color);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
  }

  .user-card:hover {
    transform: translateY(-8px) scale(1.02) !important;
    box-shadow: 0 20px 40px rgba(15, 62, 43, 0.12);
    z-index: 10;
  }

  .card-left {
    top: 40px;
    left: 0;
    transform: rotate(-3deg);
  }

  .card-right {
    bottom: 40px;
    right: 0;
    transform: rotate(3deg);
  }

  .user-img-wrapper {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1rem;
    background-color: var(--bg-sand);
  }

  .user-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .user-name {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
  }

  .user-stat {
    font-size: 0.85rem;
    color: var(--accent-green);
    font-weight: 700;
  }

  @media (max-width: 992px) {
    .how-it-works-container {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .user-cards-container {
      height: 400px;
    }
  }

  @media (max-width: 576px) {
    .how-ctas {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    .how-ctas .btn {
      width: 100%;
    }
    .user-cards-container {
      height: 320px;
    }
    .user-card {
      width: 170px;
    }
    .card-left {
      top: 20px;
    }
    .card-right {
      bottom: 20px;
    }
  }
</style>
